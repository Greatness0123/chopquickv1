# ==========================================================================
# ChopQuick Environment Variables (.env)
# ==========================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file with real values to version control
# ==========================================================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard
# 1. Create a Supabase project
# 2. Go to Settings > API
# 3. Copy the Project URL and Anon Key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Paystack Configuration
# Get this from: https://dashboard.paystack.com/settings/developers
# 1. Sign up for a Paystack account
# 2. Go to Settings > Developers
# 3. Copy your Public Key (starts with 'pk_live_' or 'pk_test_')
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here (pk_test_e782406696d56fe847900a7949143a4fbb4acdc5)

# ==========================================================================
# Notes:
# - Leave Supabase variables blank or with placeholders to run in mock mode
# - Leave Paystack blank to simulate payments without real transactions
# - Once configured, restart the dev server: npm run dev
# ==========================================================================
